# ─── AWS Configuration ──────────────────────────────────────────────────────
# AWS Region - Always use KSA (Riyadh) region for PDPL compliance
AWS_REGION=me-central-1

# AWS Credentials (use IAM roles in production; these are for local dev only)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_SESSION_TOKEN=your-session-token  # Only needed for temporary credentials

# ─── DynamoDB Tables ─────────────────────────────────────────────────────────
DYNAMODB_USERS_TABLE=nahj-users
DYNAMODB_TRANSACTIONS_TABLE=nahj-transactions
DYNAMODB_AUDIT_TABLE=nahj-audit-logs

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=نهج
NEXT_PUBLIC_APP_VERSION=1.0.0

# ─── Security ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000
